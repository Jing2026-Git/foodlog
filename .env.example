# AI API 配置
# 提供商可选：openai / anthropic / aliyun / openrouter / custom
# 也可在 Web 端"设置"页面配置（保存到 data/ai_config.json，优先级高于环境变量）
AI_API_PROVIDER=openai          # openai / anthropic / aliyun / openrouter / custom
AI_API_KEY=your-api-key-here
AI_API_BASE_URL=                 # 可选，用于兼容第三方接口
AI_MODEL=                        # 可选，默认根据 provider 自动选择

# OpenRouter（推荐，免费模型可用）
# AI_API_PROVIDER=openrouter
# AI_API_KEY=sk-or-v1-xxx
# AI_API_BASE_URL=https://openrouter.ai/api/v1
# AI_MODEL=google/gemini-2.0-flash-exp:free

# 数据库路径（可选，默认为 data/foodlog.db）
DATABASE_PATH=data/foodlog.db

# Web服务端口（可选，默认8000）
WEB_PORT=8000
